import java.util.*;
class Stack{
  int size;
  int top;
  int[] arr;
  Stack(int size){
    this.size=size;
    this.top=-1;
    this.arr=new int[size];
  }
  boolean isFull(){
    if(top==size-1)
      return true;
    else 
      return false;
  }
  boolean isEmpty(){
    if(top==-1)
     return true;
    else 
     return false;
  }
  void push(int num){
    if(isFull())
     System.out.println("Stack is overflow");
    else 
     arr[++top]=num;
  }
  void pop(){
    if(isEmpty())
     System.out.println("Stack is underflow");
    else 
      System.out.println(arr[top--]);
  }
  void peek(){
     if(isEmpty())
     System.out.println("Stack is underflow");
     else 
       System.out.println(arr[top]);
  }
  void traverse(){
     if(isEmpty())
     System.out.println("Stack is underflow");
     else 
      for(int i=0;i<=top;i++){
        System.out.print(arr[i]+" ");
      }
  }
} 
public class Main {
    public static void main(String[] args) {
     Scanner sc=new Scanner(System.in);
     int n=sc.nextInt();
     int op;
     Stack s= new Stack(n);
     while(true){
       op=sc.nextInt();
       switch(op){
         case 1:
           int num=sc.nextInt();
           s.push(num);
           break;
        case 2:
          s.pop();
          break;
        case 3:
          s.peek();
          break;
        case 4:
          s.traverse();
          break;
        case 5:
          return;
       }
     }
    }
}
