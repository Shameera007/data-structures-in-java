import java.util.*;

public class Main {
    public static void main(String[] args) {
     Scanner sc=new Scanner(System.in);
     int[] arr={4,5,8,4,9};
     int target=8;
     int i=0;
     int j=arr.length-1;
     while(i<arr.length&&j>=0){
       if(arr[i]+arr[j]==target)
        { System.out.print(arr[i]+"  "+arr[j]);
         break;
        }
        else if(arr[i]+arr[j]<target)
        i++;
        else
        j--;
     }
    }
}
