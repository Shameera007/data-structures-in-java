import java.util.*;

public class Main {
    public static void main(String[] args) {
     Scanner sc=new Scanner(System.in);
     String s=sc.nextLine();
     Stack<Character> stack=new Stack<>();
     for(int i=0;i<s.length();i++){
       stack.push(s.charAt(i));
     }
     String reverse="";
     while(!stack.isEmpty()){
      reverse+=stack.pop();
     }
     System.out.print(reverse);
    }
}
