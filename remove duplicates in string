import java.util.*;

public class Main {
    public static void main(String[] args) {
     Scanner sc=new Scanner(System.in);
     HashSet <Character> set=new HashSet<>();
     String s=sc.nextLine();
     StringBuilder sb=new StringBuilder();
     for(char c:s.toCharArray()){
       if(!set.contains(c)){
         set.add(c);
         sb.append(c);
       }
     }
     System.out.println(sb);
     
    }
}
