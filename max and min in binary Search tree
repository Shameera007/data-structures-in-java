import java.util.*;
class Node{
  int data;
  Node left;
  Node right;
  Node(int data){
    this.data=data;
    this.left=null;
    this.right=null;
  }
}
class bst{
  Node root=null;
  Node create(Node root,int val){
  if(root==null)
    root=new Node(val);
  if(root.data<val)
    root.right=create(root.right,val);
  if(root.data>val)
   root.left=create(root.left,val);
  return root;
  }
  int max(Node root){
    int max=root.data;
    while(root.right!=null){
      root=root.right;
      max=root.data;
    }
    return max;
  }
  int min(Node root){
    int min=root.data;
    while(root.left!=null){
      root=root.left;
      min=root.data;
    }
    return min;
  }
}
public class Main {
    public static void main(String[] args) {
   Scanner sc=new Scanner(System.in);
   int n=sc.nextInt();
   bst tree=new bst();
   for(int i=0;i<n;i++){
     int num=sc.nextInt();
     tree.root=tree.create(tree.root,num);
   }
   System.out.println(tree.min(tree.root));
    System.out.println(tree.max(tree.root));
    }
}
