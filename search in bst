import java.util.*;
class Node{
  int data;
  Node left;
  Node right;
  Node(int data){
    this.data=data;
    this.left=null;
    this.right=null;
  }
}
class BST{
  Node root=null;
  Node create(Node root,int val){
    if(root==null)
      root=new Node(val);
    if(root.data>val)
     root.left=create(root.left,val);
   if(root.data<val)
     root.right=create(root.right,val);
  return root;
  }
  Node search(Node root,int val){
    if(root==null||root.data==val)
      return root;
   if(root.data<val){
     return search(root.right,val);
   }
     else
    return search(root.left,val);
  }
}
public class Main {
    public static void main(String[] args) {
    Scanner sc=new Scanner(System.in);
    int n=sc.nextInt();
    BST tree=new BST();
    for(int i=0;i<n;i++){
      int num=sc.nextInt();
      tree.root=tree.create(tree.root,num);
    }
    int val=sc.nextInt();
    if(tree.search(tree.root,val)==null)
     System.out.print("false");
    else 
      System.out.print("true");
    }
}
