import java.util.*;
class Node{
  int data;
  Node next;
  Node prev;
  Node(int data){
    this.data=data;
    this.next=null;
    this.prev=null;
  }
}
class CircularD{
  Node head,tail;
  CircularD(){
    head=null;
    tail=null;
  }
  void create(int num){
  Node  newNode=new Node(num);
  if(head==null){
    head=newNode;
    tail=newNode;
  }
  else{
    tail.next=newNode;
    newNode.prev=tail;
     tail=newNode; 
  }
    head.prev=tail;
  tail.next=head;
 
  }
  
  void display(){
    Node itr=head;
    do{
      System.out.println(itr.prev+" "+itr.data+" "+itr.next);
      itr=itr.next;
    }while(itr!=head);
  }
}

public class Main {
    public static void main(String[] args) {
Scanner sc=new Scanner(System.in);
int n=sc.nextInt();
CircularD c=new CircularD();
int num;
for(int i=0;i<n;i++){
  num=sc.nextInt();
  c.create(num);
}
c.display();
    }
}
